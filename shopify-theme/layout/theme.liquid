<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="LOWKEY — Understated luxury streetwear. Not Made For All." />
    <meta name="theme-color" content="#0D0D0D" />
    <title>{{ page_title }} — {{ shop.name }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    {{ content_for_header }}
    {{ 'lowkey.css' | asset_url | stylesheet_tag }}
    <script>if(localStorage.getItem('lowkey-theme')==='light')document.documentElement.classList.add('light');</script>
  </head>
  <body class="grain">
    {%- section 'header' -%}

    <div id="cart-bg" class="cart-bg" onclick="closeCart()"></div>
    <div id="cart-panel" class="cart-panel">
      <div class="cart-head">
        <h2>BAG (<span class="cart-count">{{ cart.item_count }}</span>)</h2>
        <button onclick="closeCart()" class="cart-close tap-xs" aria-label="Close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="cart-body" id="cart-body"></div>
      <div class="cart-foot" id="cart-foot" style="display:none">
        <div class="cart-total"><span>Total</span><span>{{ cart.total_price | money }}</span></div>
        <a href="/checkout" class="cart-checkout tap-sm">Checkout</a>
      </div>
    </div>

    <main>{{ content_for_layout }}</main>

    {%- section 'footer' -%}

    <script src="{{ 'lowkey.js' | asset_url }}" defer></script>
  </body>
</html>
