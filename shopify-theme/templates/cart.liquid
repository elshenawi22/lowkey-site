<section class="c-bg" style="padding-top:7rem;padding-bottom:6rem;min-height:100vh">
  <div class="px" style="max-width:36rem;margin:0 auto">
    <h1 class="h-lg c-fg" style="margin-bottom:2rem">Bag</h1>
    <div class="sep" style="margin-bottom:2rem"></div>
    {%- if cart.item_count == 0 -%}
      <div style="text-align:center;padding:4rem 0">
        <p class="c-fg3" style="font-size:0.6875rem;letter-spacing:0.3em;text-transform:uppercase;margin-bottom:2rem">Your bag is empty</p>
        <a href="/collections/all" class="drop__cta tap-sm" style="display:inline-block;padding:1rem 3rem">Continue Shopping</a>
      </div>
    {%- else -%}
      {%- for item in cart.items -%}
        <div class="cart-item">
          <div class="cart-item__img"><img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title }}"></div>
          <div class="cart-item__info">
            <div>
              <p class="cart-item__name">{{ item.product.title }}</p>
              <p class="cart-item__meta">{% if item.variant.title != 'Default Title' %}{{ item.variant.title }} · {% endif %}Qty: {{ item.quantity }}</p>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-top:auto">
              <span class="cart-item__price">{{ item.final_line_price | money }}</span>
              <a href="/cart/change?id={{ item.key }}&quantity=0" class="cart-item__rm tap">Remove</a>
            </div>
          </div>
        </div>
      {%- endfor -%}
      <div style="border-top:1px solid var(--c-line);padding-top:1.5rem;margin-top:0.5rem">
        <div class="cart-total"><span>Total</span><span>{{ cart.total_price | money }}</span></div>
        <a href="/checkout" class="cart-checkout tap-sm">Checkout</a>
      </div>
    {%- endif -%}
  </div>
</section>
