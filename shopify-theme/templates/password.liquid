<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }}</title>
  {{ 'lowkey.css' | asset_url | stylesheet_tag }}
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;600&family=Inter:wght@300;400&display=swap" rel="stylesheet">
</head>
<body class="grain" style="background:#0D0D0D;color:#E6E2DB;display:flex;align-items:center;justify-content:center;min-height:100vh;font-family:'Inter',sans-serif">
  <div style="text-align:center;padding:2rem">
    <h1 style="font-family:'Space Grotesk',sans-serif;font-size:1.5rem;font-weight:600;letter-spacing:0.5em;margin-bottom:1rem">LOWKEY</h1>
    <p style="font-size:0.625rem;letter-spacing:0.5em;text-transform:uppercase;color:rgba(198,169,108,0.5);margin-bottom:3rem">Not Made For All.</p>
    <p style="font-size:0.75rem;color:rgba(230,226,219,0.5);margin-bottom:2rem">{{ shop.password_message }}</p>
    {%- form 'storefront_password' -%}
      <div style="display:flex;gap:0.5rem;max-width:20rem;margin:0 auto">
        <input type="password" name="password" placeholder="Password" style="flex:1;background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.07);padding:0.75rem 0;color:#E6E2DB;font-size:0.625rem;letter-spacing:0.1em;outline:none;font-family:'Inter',sans-serif">
        <button type="submit" style="color:rgba(198,169,108,0.5);font-size:0.5625rem;letter-spacing:0.3em;text-transform:uppercase;background:none;border:none;cursor:pointer;font-family:'Inter',sans-serif">Enter</button>
      </div>
      {%- if form.errors -%}
        <p style="margin-top:1rem;font-size:0.625rem;color:rgba(255,100,100,0.7)">{{ form.errors | default_errors }}</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</body>
</html>
